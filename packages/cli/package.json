{
  "name": "agentic-insights",
  "version": "0.1.0",
  "description": "Launch a local dashboard for coding-agent insights with water-impact estimates",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/max-stoddard/agentic-insights.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/max-stoddard/agentic-insights#readme",
  "bugs": {
    "url": "https://github.com/max-stoddard/agentic-insights/issues"
  },
  "bin": {
    "agentic-insights": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/prepare-runtime.mjs",
    "prepack": "npm run build -w @agentic-insights/shared && npm run build -w @agentic-insights/server && npm run build -w @agentic-insights/web && npm run build",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "fastify": "^5.2.1"
  }
}
